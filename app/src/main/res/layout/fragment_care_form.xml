<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.asagiry.plantdiary.ui.care.CareFormViewModel" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/select_plant">

                <AutoCompleteTextView
                    android:id="@+id/plant_selector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pick_next_watering_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text='@{viewModel.nextWateringDisplay.isEmpty() ? @string/next_watering_date : viewModel.nextWateringDisplay}' />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                app:visibleWhen="@{viewModel.isGardenPlant}">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pick_care_planting_date_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text='@{viewModel.plantingDateDisplay.isEmpty() ? @string/planting_date : viewModel.plantingDateDisplay}' />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pick_care_planting_time_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text='@{viewModel.plantingTimeDisplay.isEmpty() ? @string/planting_time : viewModel.plantingTimeDisplay}' />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_care_record_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/save" />

        </LinearLayout>
    </ScrollView>
</layout>

